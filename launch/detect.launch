<?xml version="1.0"?>
<launch>
    <arg name="bag_file"             default=""/>
    <arg name="image_topic"          default="/hikcamera/image_2/compressed"/>
    <arg name="confidence_threshold" default="0.45"/>
    <arg name="rate"                 default="1.0"/>

    <node pkg="aae4011_vehicle_detection"
          type="detector_node.py"
          name="vehicle_detector_node"
          output="screen">
        <param name="image_topic"          value="$(arg image_topic)"/>
        <param name="confidence_threshold" value="$(arg confidence_threshold)"/>
    </node>

    <node pkg="rosbag" type="play" name="rosbag_player"
          args="--clock -r $(arg rate) $(arg bag_file)"
          output="screen"/>
</launch>
